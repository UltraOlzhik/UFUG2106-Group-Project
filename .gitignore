.gitignore 

# Python cache files
__pycache__/
*.py[cod]

# Local Codex metadata
.codex

# Working notes not meant for submission
transcript/

# LaTeX auxiliary files
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc

# Keep the source and final report artifact
!report/report.tex
!report/report.pdf

# Generated report build directory
report/build/
